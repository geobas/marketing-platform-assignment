{
    "preset": "laravel",
    "rules": {
        "concat_space": {
            "spacing": "one"
        },
        "ordered_imports": {
            "sort_algorithm": "alpha"
        },
        "no_unused_imports": true,
        "no_extra_blank_lines": {
            "tokens": [
                "extra"
            ]
        },
        "trailing_comma_in_multiline": {
            "elements": ["arrays"]
        },
        "single_quote": true,
        "indentation_type": true,
        "phpdoc_align": false,
        "declare_strict_types": true
    },
    "exclude": [
        "bootstrap",
        "node_modules",
        "storage",
        "vendor"
    ]
}
